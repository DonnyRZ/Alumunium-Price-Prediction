GEMINI_API_KEY=PASTE_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-3-pro
NEWS_SENTIMENT_PROMPT_VERSION=pilot_v1
NEWS_SENTIMENT_INPUT_PATH=data/news/staging/gdelt_eda_candidate_model_news_v4.csv
NEWS_SENTIMENT_SCORED_OUTPUT_PATH=data/news/scored/gdelt_candidate_model_scored_v1.csv
NEWS_SENTIMENT_DAILY_OUTPUT_PATH=data/news/features/gdelt_daily_sentiment_features_v1.csv
NEWS_SENTIMENT_OVERLAY_OUTPUT_PATH=data/news/features/gdelt_daily_overlay_signals_v1.csv
NEWS_SENTIMENT_SLEEP_SECONDS=1.0
NEWS_SENTIMENT_MAX_SNIPPET_CHARS=1200
NEWS_SENTIMENT_MAX_REASON_CHARS=160
NEWS_SENTIMENT_CONFIDENCE_THRESHOLD=0.60
NEWS_OVERLAY_MIN_NEWS_COUNT=1
NEWS_OVERLAY_MIN_HIGH_CONF_RATIO=0.50
NEWS_OVERLAY_MEDIUM_SENTIMENT_THRESHOLD=0.30
NEWS_OVERLAY_STRONG_SENTIMENT_THRESHOLD=0.70
